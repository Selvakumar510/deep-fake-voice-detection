{
  "compilerOptions": {
        "target": "ES6",
    "module": "ESNext",
    "lib": ["dom", "es6"],
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
     "baseUrl": "src",
    "paths": {
      "@/*": ["*"]
    }
  }
 
}